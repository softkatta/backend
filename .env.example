APP_NAME="SoftKatta Solutions"
APP_ENV=local
# Run: php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
SOFTKATTA_CENTRAL_API_URL=https://softkatta.com/api/v1
SOFTKATTA_COMPANY_API_URL=https://softkatta.com/api/v1/company
SOFTKATTA_COMPANY_TIMESTAMP_SKEW=300

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=softkatta
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@softkatta.com"
MAIL_FROM_NAME="${APP_NAME}"
# Optional fallback when Admin → Integrations SMTP is not configured.
# Brevo: host smtp-relay.brevo.com, port 587, username = your Brevo email, password = SMTP key from Brevo dashboard.
# Hosting: host mail.yourdomain.com, username = noreply@yourdomain.com, password = email account password.

# Payment Gateways
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_KEY=
STRIPE_SECRET=
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# WhatsApp API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# Central License API
CENTRAL_API_SECRET=

# Super Admin
SUPER_ADMIN_NAME="Founder / Owner"
SUPER_ADMIN_EMAIL=admin@softkatta.com
SUPER_ADMIN_PASSWORD=

# Company Details
COMPANY_NAME="SoftKatta Solutions"
COMPANY_GST=
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=info@softkatta.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
