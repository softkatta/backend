APP_NAME="SoftKatta Solutions"
APP_ENV=production
# Run once on server: php artisan key:generate --force
APP_KEY=
APP_DEBUG=false
# API origin (Laravel). Must match the host that serves /api and /storage.
APP_URL=https://api.softkatta.in

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Keep production logs lean (error|warning). Use debug only while investigating.
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=softkatta
DB_USERNAME=softkatta
DB_PASSWORD=

# Public website (Vite SPA)
FRONTEND_URL=https://softkatta.in

# SPA origins allowed to call the API with credentials
CORS_ALLOWED_ORIGINS=https://softkatta.in,https://www.softkatta.in

# Domains that may use cookie/Sanctum stateful auth
SANCTUM_STATEFUL_DOMAINS=softkatta.in,www.softkatta.in,api.softkatta.in

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Leading dot shares cookies across softkatta.in + www + api if needed
SESSION_DOMAIN=.softkatta.in
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
# public disk is required for chatbot robot uploads, logos, product media (/storage/...)
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@softkatta.in"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Super Admin — created automatically by: php artisan migrate --seed
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_EMAIL=admin@softkatta.in
SUPER_ADMIN_PASSWORD=SoftKatta@123

# Payment Gateways
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_KEY=
STRIPE_SECRET=
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# WhatsApp API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Central License API
CENTRAL_API_SECRET=
SOFTKATTA_CENTRAL_API_URL=
SOFTKATTA_COMPANY_API_URL=
SOFTKATTA_COMPANY_TIMESTAMP_SKEW=300

# Company defaults (overridden by Admin → Settings in DB)
COMPANY_NAME="SoftKatta Solutions"
COMPANY_EMAIL=support@softkatta.in
COMPANY_PHONE=+917038452357
COMPANY_ADDRESS="Talni, Nanded, Maharashtra, India"
